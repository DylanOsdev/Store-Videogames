# Copia este archivo a .env y completa los valores.
# Genera DJANGO_SECRET_KEY:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Genera DJANGO_FERNET_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# === Django ===
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# === Cifrado de secretos en reposo (claves digitales, credenciales) ===
DJANGO_FERNET_KEY=

# === PostgreSQL ===
POSTGRES_DB=videojuegos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# === CORS (frontend Astro) ===
CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# === Celery / Redis ===
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# === Rate limiting (formato DRF: "N/min", "N/hour", "N/day") ===
THROTTLE_LOGIN=10/min
THROTTLE_REGISTER=5/min
THROTTLE_CHECKOUT=30/min
THROTTLE_WEBHOOK=120/min

# === Email (entrega de claves al cliente) ===
# En local se usa la consola por defecto. Para enviar de verdad, configura SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-responder@gamestore.local

# === Wompi (sandbox) — obtén tus llaves en https://comercios.wompi.co ===
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_BASE_URL=https://api-sandbox.co.uat.wompi.dev/v1

# === Producción (solo aplican cuando DJANGO_DEBUG=False) =====================
# En producción es OBLIGATORIO: DJANGO_DEBUG=False, un DJANGO_SECRET_KEY real,
# DJANGO_ALLOWED_HOSTS con tus dominios y servir tras HTTPS.
#
# Dominios del frontend/admin para confianza CSRF (incluye el esquema https://):
# DJANGO_CSRF_TRUSTED_ORIGINS=https://tienda.tudominio.com,https://admin.tudominio.com
#
# Forzar redirección a HTTPS (déjalo en True salvo que el proxy ya lo haga):
# DJANGO_SECURE_SSL_REDIRECT=True
#
# HSTS: empieza bajo (3600 = 1h) y súbelo a 31536000 (1 año) cuando confirmes
# que todo el tráfico va por HTTPS sin romperse:
# DJANGO_HSTS_SECONDS=3600
