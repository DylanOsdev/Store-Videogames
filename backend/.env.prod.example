# ===========================================================================
# Variables de PRODUCCIÓN del backend.  Copia este archivo a backend/.env.prod
# y completa los valores reales.  NUNCA lo subas al repositorio.
#
# Generar secretos:
#   DJANGO_SECRET_KEY:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   DJANGO_FERNET_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ===========================================================================

# === Django (obligatorio en prod) ==========================================
DJANGO_DEBUG=False
# Llave real y larga (NO la de desarrollo). Sin esto el backend se niega a arrancar.
DJANGO_SECRET_KEY=
# Dominios/host que sirven la app. Incluye el host con que la alcanzas.
# Para pruebas locales del stack vale: localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# === Cifrado en reposo de las claves digitales (obligatorio) ===============
DJANGO_FERNET_KEY=

# === PostgreSQL ============================================================
# HOST=db -> nombre del servicio en docker-compose.prod.yml
POSTGRES_DB=videojuegos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === CORS ==================================================================
# Con nginx el navegador habla al MISMO origen, así que normalmente no se
# necesita CORS. Si sirves el frontend en otro dominio, lístalo aquí.
CORS_ALLOWED_ORIGINS=

# === Frontend / enlaces por correo =========================================
# URL pública del frontend. Se usa para construir el enlace de "restablecer
# contraseña" que se envía por correo. Detrás de nginx (mismo origen) apunta
# al dominio público con el que sirves la app, p.ej. https://tu-dominio.com
FRONTEND_URL=http://localhost:8080
# Caducidad del enlace de restablecimiento, en segundos (por defecto 2 horas).
# PASSWORD_RESET_TIMEOUT=7200

# === Celery / Redis ========================================================
# (docker-compose.prod.yml ya define estos valores; puedes sobrescribir aquí.)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# En prod las tareas corren en el worker, NO de forma síncrona.
CELERY_TASK_ALWAYS_EAGER=False

# === Email (entrega de claves / notificaciones) ============================
# Activa el envío real por SMTP. Si dejas el de consola, los correos NO se
# envían (se imprimen en el log): el comprador no recibiría su clave.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# TLS (STARTTLS, puerto 587) y SSL (cifrado directo, puerto 465) son
# EXCLUYENTES. Para 587 deja EMAIL_USE_TLS=True; para 465 usa EMAIL_USE_SSL=True
# (y EMAIL_USE_TLS se ignora).
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# Segundos antes de abortar una conexión SMTP colgada (no bloquea el worker).
EMAIL_TIMEOUT=10
# Remitente por defecto. Usa un dominio que tu proveedor SMTP autorice.
DEFAULT_FROM_EMAIL=GameStore <no-reply@tu-dominio.com>
#
# Verifica la config sin crear un pedido real:
#   docker compose -f docker-compose.prod.yml exec backend \
#     python manage.py send_test_email --to tu-correo@ejemplo.com

# === Wompi (producción) — llaves del comercio ==============================
# En prod usa llaves prv_prod_/pub_prod_ y la URL de producción de Wompi.
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_BASE_URL=https://production.wompi.co/v1

# === Rate limiting (opcional; estos son los valores por defecto) ===========
# THROTTLE_LOGIN=10/min
# THROTTLE_REGISTER=5/min
# THROTTLE_PASSWORD_RESET=5/min
# THROTTLE_CHECKOUT=30/min
# THROTTLE_WEBHOOK=120/min

# === HTTPS / endurecimiento ================================================
# IMPORTANTE sobre SECURE_SSL_REDIRECT:
#   - El stack base sirve por HTTP en el puerto 80 (nginx no termina TLS).
#   - Con DEBUG=False, Django redirige a HTTPS por defecto. Si lo dejas en True
#     SIN tener TLS real, entrarás en un bucle de redirección y hasta el
#     healthcheck del backend fallará. Por eso aquí va en False.
#   - Cuando pongas un certificado (TLS en nginx o en un balanceador delante),
#     cámbialo a True y añade tus dominios https en DJANGO_CSRF_TRUSTED_ORIGINS.
DJANGO_SECURE_SSL_REDIRECT=False
# Confianza CSRF para el admin y formularios (incluye el esquema, p.ej. https://):
DJANGO_CSRF_TRUSTED_ORIGINS=
# HSTS: empieza bajo y súbelo a 31536000 cuando confirmes HTTPS estable.
DJANGO_HSTS_SECONDS=3600
