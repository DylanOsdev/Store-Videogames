---
import type { Product } from "../lib/types";
import { formatCOP } from "../lib/format";
import AddToCartButton from "./AddToCartButton.tsx";

interface Props {
  product: Product;
}
const { product } = Astro.props;

const platformName =
  typeof product.platform === "string"
    ? product.platform
    : product.platform?.name;
---

<article class="card" style="overflow:hidden; display:flex; flex-direction:column;">
  <a href={`/producto/${product.slug}`} style="display:block;">
    <div
      style="aspect-ratio:3/4; background:var(--bg-elev); display:flex; align-items:center; justify-content:center; overflow:hidden;"
    >
      {
        product.cover_image ? (
          <img
            src={product.cover_image}
            alt={product.title}
            style="width:100%; height:100%; object-fit:cover;"
            loading="lazy"
          />
        ) : (
          <span style="font-size:3rem; opacity:0.3;">🎮</span>
        )
      }
    </div>
  </a>

  <div style="padding:0.9rem; display:flex; flex-direction:column; gap:0.5rem; flex:1;">
    <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
      <span class="badge">{platformName}</span>
      <span class="badge" style="background:rgba(43,212,168,0.15); color:#7eebcd;">
        {product.delivery_type_display}
      </span>
    </div>

    <a href={`/producto/${product.slug}`}>
      <h3 style="margin:0; font-size:1rem; line-height:1.3;">{product.title}</h3>
    </a>

    <div style="margin-top:auto; display:flex; flex-direction:column; gap:0.6rem;">
      <strong style="font-size:1.15rem;">{formatCOP(product.price)}</strong>
      <AddToCartButton product={product} block client:visible />
    </div>
  </div>
</article>
