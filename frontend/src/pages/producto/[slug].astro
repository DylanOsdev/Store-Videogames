---
import Layout from "../../layouts/Layout.astro";
import AddToCartButton from "../../components/AddToCartButton.tsx";
import { API_BASE } from "../../lib/config";
import { formatCOP } from "../../lib/format";
import type { Product } from "../../lib/types";

export const prerender = false;

const { slug } = Astro.params;

let product: Product | null = null;
let notFound = false;

try {
  const res = await fetch(`${API_BASE}/catalog/products/${slug}/`);
  if (res.ok) {
    product = (await res.json()) as Product;
  } else if (res.status === 404) {
    notFound = true;
  }
} catch {
  notFound = true;
}

if (!product) {
  Astro.response.status = 404;
}

const platformName =
  product && typeof product.platform === "object"
    ? product.platform.name
    : (product?.platform as string);
const categoryName =
  product && typeof product.category === "object"
    ? product.category.name
    : (product?.category as string);
---

<Layout title={product ? `${product.title} — GameStore` : "Producto no encontrado"}>
  {
    !product ? (
      <div class="card" style="padding:2rem; text-align:center;">
        <h1 style="margin:0 0 0.5rem;">Producto no encontrado</h1>
        <p class="muted">El producto que buscas no existe o no está disponible.</p>
        <a href="/" class="btn" style="margin-top:1rem;">
          Volver al catálogo
        </a>
      </div>
    ) : (
      <div style="display:grid; grid-template-columns:minmax(0,360px) 1fr; gap:2.5rem; align-items:start;">
        <div
          class="card"
          style="aspect-ratio:3/4; overflow:hidden; display:flex; align-items:center; justify-content:center;"
        >
          {product.cover_image ? (
            <img
              src={product.cover_image}
              alt={product.title}
              style="width:100%; height:100%; object-fit:cover;"
            />
          ) : (
            <span style="font-size:5rem; opacity:0.3;">🎮</span>
          )}
        </div>

        <div style="display:flex; flex-direction:column; gap:1rem;">
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
            <span class="badge">{platformName}</span>
            <span class="badge">{categoryName}</span>
            <span
              class="badge"
              style="background:rgba(43,212,168,0.15); color:#7eebcd;"
            >
              {product.delivery_type_display}
            </span>
          </div>

          <h1 style="margin:0; font-size:2rem;">{product.title}</h1>
          <strong style="font-size:1.6rem;">{formatCOP(product.price)}</strong>

          <p
            style={`margin:0; font-weight:600; color:${product.in_stock ? "var(--accent)" : "var(--danger)"};`}
          >
            {product.in_stock ? "Disponible — entrega inmediata" : "Agotado"}
          </p>

          {product.description && (
            <p class="muted" style="line-height:1.6;">
              {product.description}
            </p>
          )}

          <div style="max-width:280px;">
            <AddToCartButton product={product} block client:load />
          </div>
        </div>
      </div>
    )
  }
</Layout>
