---
import "../styles/global.css";
import Navbar from "../components/Navbar.tsx";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "GameStore — Videojuegos digitales",
  description = "Compra videojuegos y claves digitales con entrega inmediata.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Navbar client:load />
    <main class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
      <slot />
    </main>
    <footer
      style="border-top:1px solid var(--border); padding:2rem 0; color:var(--text-dim);"
    >
      <div class="container" style="font-size:0.85rem;">
        GameStore · Plataforma de venta de videojuegos digitales
      </div>
    </footer>
  </body>
</html>
