# ===========================================================================
# Variables del stack de PRODUCCIÓN (raíz). Copia a .env.prod y complétalo.
# Estas variables las consume docker-compose.prod.yml.
#
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# ===========================================================================

# === Puerto público de nginx (único expuesto al host) ======================
NGINX_PORT=80

# === PostgreSQL (deben coincidir con backend/.env.prod) ====================
POSTGRES_DB=videojuegos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-clave

# === Variables de BUILD del frontend (se hornean en el bundle del navegador) =
# PUBLIC_API_URL VACÍO => el navegador usa rutas relativas (/api) vía nginx.
# Déjalo vacío salvo que sirvas la API en otro dominio.
PUBLIC_API_URL=
# Llave PÚBLICA de Wompi (no es secreta; va en el cliente).
PUBLIC_WOMPI_PUBLIC_KEY=
# URL del widget de Wompi (producción).
PUBLIC_WOMPI_WIDGET_URL=https://checkout.wompi.co/widget.js
